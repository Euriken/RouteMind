OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_HOST=http://ollama:11434

# ⚠️  REQUIRED for Fireworks escalation — harness will return 502 errors on
# escalated tasks if this is missing. Get your key at:
# https://fireworks.ai/settings/users/api-keys
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Optional — override number of self-consistency runs globally (default: per-difficulty)
# CONFIDENCE_N_RUNS=3

# Optional — Ollama timeout tuning (seconds)
# OLLAMA_CONNECT_TIMEOUT_S=5    # connect-phase timeout: fast-fail on dead container
# OLLAMA_READ_TIMEOUT_S=120     # inference timeout: allow slow CPU inference to complete
